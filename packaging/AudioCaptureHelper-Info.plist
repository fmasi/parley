<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>eu.fmasi.parley.capture-helper</string>

    <key>CFBundleName</key>
    <string>AudioCaptureHelper</string>

    <key>CFBundleVersion</key>
    <string>2.0.0</string>

    <key>CFBundlePackageType</key>
    <string>XPC!</string>

    <key>CFBundleExecutable</key>
    <string>audio-capture-helper-xpc</string>

    <!-- The helper opens an AVCaptureSession for the mic (#96), so its bundle needs its own
         microphone usage string. Without it a bundled XPC service that touches the mic can be
         terminated by TCC (council HOL-2). It also drives Screen Recording (system audio). -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Parley needs microphone access to record your voice.</string>

    <key>NSScreenCaptureUsageDescription</key>
    <string>Parley needs Screen Recording permission to capture system audio from meetings.</string>

    <!-- SystemTapSession calls AudioHardwareCreateProcessTap from THIS process (the XPC helper), so
         the System Audio Recording TCC grant is keyed to this bundle, not the main app (#103). -->
    <key>NSAudioCaptureUsageDescription</key>
    <string>Parley needs System Audio Recording permission to capture meeting and call audio (including Continuity calls).</string>

    <key>XPCService</key>
    <dict>
        <key>ServiceType</key>
        <string>Application</string>
    </dict>
</dict>
</plist>
